{
  "name": "data-portal",
  "version": "2.5.13",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "typecheck": "tsc -b --pretty false",
    "typecheck:watch": "tsc -b -w --pretty false",
    "typecheck:ng": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint",
    "lf": "ng lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "test:ui": "ng test --ui --runner-config vitest.ui.config.ts",
    "e2e": "playwright test --project chromium",
    "e2e:all": "playwright test --workers=2",
    "e2e:debug": "playwright test --project chromium --debug",
    "e2e:headed": "playwright test --project chromium --headed",
    "e2e:ui": "playwright test --project chromium --ui",
    "e2e:report": "playwright show-report --host 0.0.0.0",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "docs": "compodoc -p tsconfig.doc.json -s -r 8081",
    "compodoc:build": "compodoc -p tsconfig.doc.json",
    "compodoc:build-and-serve": "compodoc -p tsconfig.doc.json -s -r 8081",
    "compodoc:serve": "compodoc -s",
    "toc": "markdown-toc-gen update README.md"
  },
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "private": true,
  "dependencies": {
    "@angular/cdk": "^22.0.3",
    "@angular/common": "^22.0.5",
    "@angular/compiler": "^22.0.5",
    "@angular/core": "^22.0.5",
    "@angular/forms": "^22.0.5",
    "@angular/material": "^22.0.3",
    "@angular/material-date-fns-adapter": "^22.0.3",
    "@angular/platform-browser": "^22.0.5",
    "@angular/router": "^22.0.5",
    "@ngneat/cashew": "^5.3.0",
    "@tailwindcss/postcss": "^4.3.2",
    "angularx-qrcode": "^21.0.5",
    "date-fns": "^4.4.0",
    "js-yaml": "^5.2.1",
    "ngx-mat-input-tel": "^22.1.0",
    "oidc-client-ts": "^3.5.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.5",
    "@compodoc/compodoc": "^2.0.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.3",
    "@playwright/test": "^1.61.1",
    "@testing-library/angular": "^19.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "angular-eslint": "^22.0.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-jsdoc": "^63.0.11",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "markdown-toc-gen": "^1.2.0",
    "msw": "^2.14.6",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "msw": {
    "workerDirectory": [
      "src/mocks"
    ]
  }
}
