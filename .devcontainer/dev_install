#!/bin/bash
# install service in dev container

cd /workspace

echo "Install pnpm..."
corepack prepare pnpm@10.33.0 --activate

echo "Add Markdown TOC generator for updating the Readme"
npm install -g markdown-toc-gen

echo "Install static web server..."
curl --proto '=https' --tlsv1.2 -sSfL https://get.static-web-server.net | sh

echo "Install CLI tools useful for development and AI agents..."
apt-get update -qq && apt-get install -y --no-install-recommends \
  ripgrep jq fd-find shellcheck shfmt bat \
  && rm -rf /var/lib/apt/lists/*
ln -sf /usr/bin/fdfind /usr/local/bin/fd
ln -sf /usr/bin/batcat /usr/local/bin/bat

echo "Install application and dev tools..."
pnpm install

echo "Install Playwright dependencies..."
pnpm exec playwright install --with-deps

# create certificates
(cd .devcontainer && ./create_cert)
