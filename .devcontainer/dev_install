#!/bin/bash
# install service in dev container
set -euo pipefail

cd /workspace

echo "Install pnpm..."
corepack prepare pnpm@11.9.0 --activate

echo "Install static web server..."
curl --proto '=https' --tlsv1.2 -sSfL https://get.static-web-server.net | sh

echo "Clean up existing node_modules to ensure fresh install..."
rm -rf node_modules .pnpm-store

echo "Install application and dev tools..."
# prefer-offline only here: keeps container setup fast and network-tolerant
# without letting stale registry metadata affect interactive update/add
pnpm install --prefer-offline

echo "Install Playwright dependencies..."
pnpm exec playwright install --with-deps

# create certificates
(cd .devcontainer && ./create_cert)
